# AI Context Poisoning Prevention
# Block paths to keep AI Token Density high

# Heavy Dependencies
node_modules/
.expo/
.venv/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build Artifacts
dist/
bundle/
build/
bin/
obj/

# Media & Binary (AI shouldn't read these as text)
assets/
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.pdf
*.zip
*.tar.gz
*.exe
*.dll

# Logs & Temp
*.log
tmp/
coverage/
*.sql

# IDE & Editor
.idea/
.vscode/
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Misc
*.tmp
*.bak
*.orig
*.rej
*.lock
*.sqlite
*.db
*.tgz
*.egg-info/
*.egg
*.whl
*.ipynb_checkpoints/
*.ipynb
*.cache
*.test.js
*.test.ts
*.test.tsx

# System generated artifacts (Brain)
.gemini/
.antigravity/
brain/

# Hardcoded Ignore
.git/
.husky/
