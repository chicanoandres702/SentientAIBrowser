{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Web",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File ./run-web.ps1",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Android",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File ./run-android.ps1",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Proxy",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File ./run-proxy.ps1",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build Web",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File ./build-web.ps1",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Deploy Firebase",
            "type": "shell",
            "command": "npm run firebase",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Sync Credentials",
            "type": "shell",
            "command": "npm run sync-credentials",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Antigravity Watch",
            "type": "shell",
            "command": "node scripts/orchestrator.service.js",
            "isBackground": true,
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^\\[Orchestrator\\] (.*)$",
                            "message": 1
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^--- Sentient GH Orchestrator Active ---$",
                        "endsPattern": "^\\[Orchestrator\\] Synchronized .*$"
                    }
                }
            ]
        },
        {
            "label": "Stop Antigravity",
            "type": "shell",
            "command": "npm run stop-antigravity",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}