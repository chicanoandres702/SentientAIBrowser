{
    "version": "2.0.0",
    "tasks": [

        // ── Expo / npm ────────────────────────────────────────────────────────────
        {
            "label": "npm: web",
            "type": "shell",
            "command": "npm",
            "args": ["run", "web"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 },
                "background": { "activeOnStart": true, "beginsPattern": ".*Expo.*", "endsPattern": ".*on the web.*" }
            },
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
        },

        t7
        {
            "label": "npm: start",
            "type": "shell",
            "command": "npm",
            "args": ["run", "start"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 },
                "background": { "activeOnStart": true, "beginsPattern": ".*Expo.*", "endsPattern": ".*Press.*" }
            },
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },

        // ── Android ───────────────────────────────────────────────────────────────
        {
            "label": "[Android] Build: preview",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-android.ps1","-Target","build","-Profile","preview"],
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true }
        },
        {
            "label": "[Android] Build + Install + Launch (Cloud Run)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy","Bypass",
                "-File","${workspaceFolder}/deploy-android.ps1",
                "-Target","adb",
                "-Profile","production"
            ],
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true }
        },
            {
                "label": "Install APK to device",
                "type": "shell",
                "command": "adb install -r ${workspaceFolder}/app-release-apk/app-release.apk"
            },
        {
            "label": "[Android] ADB: build + install + launch",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-android.ps1","-Target","adb","-SkipTsCheck"],
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true }
        },
        {
            "label": "[Android] GitHub: download release APK + ADB install",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy","Bypass",
                "-File","${workspaceFolder}/deploy-android.ps1",
                "-Target","gh-adb"
            ],
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true, "focus": true }
        },
        {
            "label": "[Android] Start ADB debug session",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/start-android-debug.ps1"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
        },

        // ── GitHub Actions deploy ─────────────────────────────────────────────────
        {
            "label": "[GitHub] Deploy: All",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","all"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "group": { "kind": "build", "isDefault": false }
        },
        {
            "label": "[GitHub] Deploy: Cloud Run only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","cloudrun"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "[GitHub] Deploy: Firebase Hosting only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","hosting"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "[GitHub] Deploy: Firestore Rules only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","functions"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "[GitHub] Deploy: All (no push)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","all","-NoPush"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },

        // ── Direct deploy (no GitHub Actions) ────────────────────────────────────
        {
            "label": "[Direct] Deploy: All",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","all"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "[Direct] Deploy: Cloud Run only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "[Direct] Deploy: Cloud Run (skip TS build)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun","-SkipBuild"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "[Direct] Deploy: Firestore Rules only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","rules"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },

        // ── Dev servers ───────────────────────────────────────────────────────────
        {
            "label": "[Dev] Run proxy server",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/run-proxy.ps1"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": false }
        },
        {
            "label": "[Dev] Run proxy (local Chrome CDP)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/run-proxy.ps1","-LocalChrome"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": false }
        },
        {
            "label": "[Dev] Serve local web (export + HTTP server)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/serve-local.ps1"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": false }
        },
        {
            "label": "[Dev] Export web to dist/",
            "type": "shell",
            "command": "npx expo export --platform web --output-dir dist",
            "group": "build",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "[Dev] Start Chrome debug session",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/start-chrome-debug.ps1"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
        },

        // ── Type-check / validate ─────────────────────────────────────────────────
        {
            "label": "[Check] TypeScript (root)",
            "type": "shell",
            "command": "npx tsc --noEmit",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$tsc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "[Check] TypeScript (functions)",
            "type": "shell",
            "command": "npx tsc --noEmit",
            "options": { "cwd": "${workspaceFolder}/functions" },
            "group": "build",
            "problemMatcher": ["$tsc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "[Check] Validate sentient code",
            "type": "shell",
            "command": "node validate-sentient-code.js",
            "group": "test",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Background watchers (auto-start on folder open) ───────────────────────
        {
            "label": "Validate Sentient Code (Watch)",
            "type": "shell",
            "command": "node",
            "args": ["validate-sentient-code.js"],
            "isBackground": true,
            "runOptions": { "runOn": "folderOpen" },
            "problemMatcher": {
                "pattern": { "regexp": "^\\[(.*)\\](.*)$", "severity": 1, "message": 2 },
                "background": { "activeOnStart": true, "beginsPattern": ".*VALIDATION.*", "endsPattern": ".*PASSED.*|.*FAILED.*" }
            },
            "presentation": { "reveal": "silent", "panel": "shared", "focus": false }
        },
        {
            "label": "Sync GitHub Tree (Watch)",
            "type": "shell",
            "command": "node",
            "args": ["sync-gh-tree.js"],
            "isBackground": true,
            "runOptions": { "runOn": "folderOpen" },
            "problemMatcher": {
                "pattern": { "regexp": "^\\[(.*?)\\](.*)$", "severity": 1, "message": 2 },
                "background": { "activeOnStart": true, "beginsPattern": ".*GH-Sync.*", "endsPattern": ".*sync.*" }
            },
            "presentation": { "reveal": "silent", "panel": "shared", "focus": false }
        },
        {
            "label": "Orchestrator Service (Watch)",
            "type": "shell",
            "command": "node",
            "args": ["orchestrator.service.js"],
            "isBackground": true,
            "runOptions": { "runOn": "folderOpen" },
            "problemMatcher": {
                "pattern": { "regexp": "^\\[(.*?)\\](.*)$", "severity": 1, "message": 2 },
                "background": { "activeOnStart": true, "beginsPattern": ".*Orchestrator.*", "endsPattern": ".*failed.*|.*Active.*" }
            },
            "presentation": { "reveal": "silent", "panel": "shared", "focus": false }
        },

        // ── Misc ──────────────────────────────────────────────────────────────────
        {
            "label": "[Util] Clear cache and rebuild web",
            "type": "shell",
            "command": "powershell",
            "args": ["-NoProfile","-ExecutionPolicy","Bypass","-Command","rm -Force -Recurse ./node_modules/.cache -ErrorAction SilentlyContinue; rm -Force -Recurse ./.expo -ErrorAction SilentlyContinue; npm run build:web"],
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "[Util] Sync Cloud Logic (legacy bat)",
            "type": "shell",
            "command": ".\\deploy-cloud.bat",
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "[IAM] Fix IAM: Grant Firebase SA deploy roles",
            "type": "shell",
            "command": "powershell",
            "args": ["-NoProfile","-ExecutionPolicy","Bypass","-Command","$SA='firebase-adminsdk-fbsvc@sentient-ai-browser.iam.gserviceaccount.com'; $P='sentient-ai-browser'; $CSA='184717935920-compute@developer.gserviceaccount.com'; gcloud projects add-iam-policy-binding $P --member=serviceAccount:$SA --role=roles/run.admin --quiet"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "Ensure GitHub CLI is installed and authenticated",
            "type": "shell",
            "command": "gh auth status",
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": true },
            "options": {
                "env": {
                    "GH_FORCE_TTY": "true"
                }
            }
        },

        // ── Compound ──────────────────────────────────────────────────────────────
        {
            "label": "[Compound] GH Auth then Full Automation",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Ensure GitHub CLI is installed and authenticated",
                "[GitHub] Deploy: All"
            ],
            "problemMatcher": []
        },
        {
            "label": "[Compound] Fix IAM then Deploy All",
            "dependsOrder": "sequence",
            "dependsOn": ["[IAM] Fix IAM: Grant Firebase SA deploy roles", "[GitHub] Deploy: All"],
            "problemMatcher": []
        },
        {
            "label": "Full Automation: Build, Download, Install APK",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "gh workflow run full-automation.yml --repo chicanoandres702/SentientAIBrowser --ref main; $runId = (gh run list --repo chicanoandres702/SentientAIBrowser | Select-String 'full-automation' | Select-Object -First 1).ToString().Split()[0]; gh run download $runId --name app-release-apk --repo chicanoandres702/SentientAIBrowser; adb install -r app-release-apk/app-release.apk"
            ]
        }
    ]
}