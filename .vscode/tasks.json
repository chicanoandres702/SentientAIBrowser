{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm: web",
            "type": "shell",
            "command": "npm",
            "args": ["run", "web"],
            "windows": {
                "command": "npm",
                "args": ["run", "web"]
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*Expo.*",
                    "endsPattern": ".*on the web.*"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            }
        },
        {
            "label": "npm: start",
            "type": "shell",
            "command": "npm",
            "args": ["run", "start"],
            "windows": {
                "command": "npm",
                "args": ["run", "start"]
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*Expo.*",
                    "endsPattern": ".*Press.*"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Sync Cloud Logic",
            "type": "shell",
            "command": ".\\deploy-cloud.bat",
            "windows": {
                "command": ".\\deploy-cloud.bat"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Clear Cache & Rebuild Web",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "rm -Force -Recurse ./node_modules/.cache -ErrorAction SilentlyContinue; rm -Force -Recurse ./.expo -ErrorAction SilentlyContinue; npm run build:web"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "rm -Force -Recurse ./node_modules/.cache -ErrorAction SilentlyContinue; rm -Force -Recurse ./.expo -ErrorAction SilentlyContinue; npm run build:web"
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "🔍 Validate Sentient Code (Watch)",
            "type": "shell",
            "command": "node",
            "args": ["validate-sentient-code.js"],
            "windows": {
                "command": "node",
                "args": ["validate-sentient-code.js"]
            },
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^\\[(.*)\\](.*)$",
                    "severity": 1,
                    "message": 2
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*VALIDATION.*",
                    "endsPattern": ".*PASSED.*|.*FAILED.*"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "focus": false
            }
        },
        {
            "label": "🔄 Sync GitHub Tree (Watch)",
            "type": "shell",
            "command": "node",
            "args": ["sync-gh-tree.js"],
            "windows": {
                "command": "node",
                "args": ["sync-gh-tree.js"]
            },
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^\\[(.*?)\\](.*)$",
                    "severity": 1,
                    "message": 2
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*GH-Sync.*",
                    "endsPattern": ".*sync.*"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "focus": false
            }
        },
        {
            "label": "🎼 Orchestrator Service (Watch)",
            "type": "shell",
            "command": "node",
            "args": ["orchestrator.service.js"],
            "windows": {
                "command": "node",
                "args": ["orchestrator.service.js"]
            },
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^\\[(.*?)\\](.*)$",
                    "severity": 1,
                    "message": 2
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*Orchestrator.*",
                    "endsPattern": ".*failed.*|.*Active.*"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "focus": false
            }
        },

        // ── IAM: grant Firebase Admin SDK service account the roles needed for CI deploy ──
        {
            "label": "🔑 Fix IAM: Grant Firebase SA deploy roles",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command",
                "$SA='firebase-adminsdk-fbsvc@sentient-ai-browser.iam.gserviceaccount.com'; $P='sentient-ai-browser'; $CSA='184717935920-compute@developer.gserviceaccount.com'; @('roles/serviceusage.serviceUsageConsumer','roles/firebaserules.admin','roles/datastore.indexAdmin','roles/run.admin','roles/storage.admin') | ForEach-Object { Write-Host \"Granting $_ on project...\"; gcloud projects add-iam-policy-binding $P --member=serviceAccount:$SA --role=$_ --quiet 2>&1 | Select-String 'Updated IAM|ERROR' }; Write-Host 'Granting iam.serviceAccountUser on compute SA (required for Cloud Run)...'; gcloud iam service-accounts add-iam-policy-binding $CSA --project=$P --member=serviceAccount:$SA --role=roles/iam.serviceAccountUser --quiet 2>&1 | Select-String 'Updated IAM|ERROR'; Write-Host 'Done. Allow ~60s for propagation.'"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },

        // ── Deploy: trigger GitHub Actions workflow ─────────────────────────
        {
            "label": "🚀 Deploy All (Firebase + Cloud Run)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "all"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
            "group": { "kind": "build", "isDefault": false }
        },
        {
            "label": "☁️  Deploy Cloud Run only",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "cloudrun"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "🔥 Deploy Firestore Rules only",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "functions"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        // Compound: grant missing IAM roles first, then full deploy
        {
            "label": "🔑+🚀 Fix IAM then Deploy All",
            "dependsOrder": "sequence",
            "dependsOn": [
                "🔑 Fix IAM: Grant Firebase SA deploy roles",
                "🚀 Deploy All (Firebase + Cloud Run)"
            ],
            "problemMatcher": []
        },

        // ── Direct deploy tasks (no GitHub Actions) ──────────────────────
        {
            "label": "🚀 Direct Deploy: All (Firebase + Cloud Run)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","all"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "☁️  Direct Deploy: Cloud Run only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "🔥 Direct Deploy: Firestore Rules only",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","rules"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        },
        {
            "label": "☁️  Direct Deploy: Cloud Run (skip TS build)",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun","-SkipBuild"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
        }
    ]
}