{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Sync Cloud Logic (Deploy)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloud.bat",
            "console": "integratedTerminal"
        },
        {
            "name": "Start Local Cloud (Emulator)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/debug-local-cloud.bat",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Android",
            "cwd": "${workspaceFolder}",
            "type": "reactnative",
            "request": "launch",
            "platform": "android"
        }
    ]
}