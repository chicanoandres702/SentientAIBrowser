{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Web (Development)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "web"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "preLaunchTask": "npm: web"
        },
        {
            "name": "Web with Debug",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "pathMapping": {
                "/": "${workspaceFolder}",
                "/static": "${workspaceFolder}"
            },
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Expo (Managed)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "start"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Android",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "android"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Android",
            "cwd": "${workspaceFolder}",
            "type": "reactnative",
            "request": "launch",
            "platform": "android"
        },
        {
            "name": "Sync Cloud Logic (Deploy All)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloud.bat",
            "console": "integratedTerminal"
        },
        {
            "name": "Firestore: Deploy Rules Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "firebase",
            "runtimeArgs": ["deploy", "--only", "firestore:rules"],
            "console": "integratedTerminal"
        },
        {
            "name": "Firestore: Deploy Indexes Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "firebase",
            "runtimeArgs": ["deploy", "--only", "firestore:indexes"],
            "console": "integratedTerminal"
        },
        {
            "name": "☁️ Deploy Functions (Build TS → Deploy)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "cmd",
            "runtimeArgs": [
                "/c",
                "cd functions && npm run build && cd .. && firebase deploy --only functions"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "🖥️ Deploy Frontend (TSX → Hosting)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "./deploy-frontend.ps1"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Proxy: Build & Deploy All",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloudrun.bat",
            "runtimeArgs": ["all"],
            "console": "integratedTerminal"
        },
        {
            "name": "Proxy: Manual Build (Docker)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloudrun.bat",
            "runtimeArgs": ["build"],
            "console": "integratedTerminal"
        },
        {
            "name": "Proxy: Manual Deploy (GCR)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloudrun.bat",
            "runtimeArgs": ["deploy"],
            "console": "integratedTerminal"
        },
        {
            "name": "Start Local Cloud (Emulator)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/debug-local-cloud.bat",
            "console": "integratedTerminal"
        },

        // ── GitHub Actions Deploy ──────────────────────────────
        {
            "name": "🚀 GitHub Deploy: All",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "all"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "� GitHub Deploy: All (NoPush)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "all",
                "-NoPush"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "🔥 GitHub Deploy: Hosting Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "hosting"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "⚡ GitHub Deploy: Firestore Rules Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "functions"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "☁️ GitHub Deploy: Cloud Run Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "cloudrun"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },

        // ── IAM fix — run this once if you get 403 Permission Denied ──
        // This grants the Firebase Admin SDK service account all required
        // deploy roles (serviceUsageConsumer, firebaserules.admin, etc.)
        {
            "name": "🔑 Fix IAM: Grant Firebase SA deploy roles",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command",
                "$SA='firebase-adminsdk-fbsvc@sentient-ai-browser.iam.gserviceaccount.com'; $P='sentient-ai-browser'; $CSA='184717935920-compute@developer.gserviceaccount.com'; @('roles/serviceusage.serviceUsageConsumer','roles/firebaserules.admin','roles/datastore.indexAdmin','roles/run.admin','roles/storage.admin') | ForEach-Object { Write-Host \"Granting $_ on project...\"; gcloud projects add-iam-policy-binding $P --member=serviceAccount:$SA --role=$_ --quiet }; Write-Host 'Granting iam.serviceAccountUser on compute SA (required for Cloud Run)...'; gcloud iam service-accounts add-iam-policy-binding $CSA --project=$P --member=serviceAccount:$SA --role=roles/iam.serviceAccountUser --quiet; Write-Host 'IAM grant complete. Allow ~60s for propagation then re-run deploy.'"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "🔑+🚀 Fix IAM then Deploy All",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "all",
                "-NoPush"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "🔑 Fix IAM: Grant Firebase SA deploy roles"
        },

        // ── Direct deploy — no GitHub Actions, pushes straight from machine ──
        {
            "name": "🚀 Direct Deploy: All (Firebase + Cloud Run)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","all"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "☁️  Direct Deploy: Cloud Run only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "🔥 Direct Deploy: Firestore Rules only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","rules"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "☁️  Direct Deploy: Cloud Run (skip TS build)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun","-SkipBuild"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "☁️  Direct Deploy: Cloud Run (force Cloud Build)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-direct.ps1","-Target","cloudrun","-UseCloudBuild"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Web + Chrome Debug",
            "configurations": ["Web (Development)", "Web with Debug"],
            "stopOnEntry": false
        },
        {
            "name": "🔑+🚀 Fix IAM → Deploy All",
            "configurations": ["🔑+🚀 Fix IAM then Deploy All"]
        }
    ]
}