{
    "version": "0.2.0",
    "configurations": [
        // ═══════════════════════════════════════════════════════════════════════
        // ANDROID
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "Android: ADB build + install + launch",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-android.ps1","-Target","adb"],
            
            "presentation": { "group": "android", "order": 1 }
        },
        {
            "name": "Android: GitHub release → ADB install",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-android.ps1","-Target","gh-adb"],
            
            "presentation": { "group": "android", "order": 2 }
        },
        {
            "name": "Android: Build preview APK",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-android.ps1","-Target","build","-Profile","preview"],
            
            "presentation": { "group": "android", "order": 3 }
        },
        {
            "name": "Android: Attach Hermes debugger (ADB)",
            "type": "node",
            "request": "attach",
            "port": 8081,
            "address": "localhost",
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/",
            "presentation": { "group": "android", "order": 4 }
        },
        {
            "name": "Android: Build + Install + Launch (Cloud Run)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-android.ps1","-Target","adb","-Profile","production"],
            "presentation": { "group": "android", "order": 5 }
        },
        {
            "name": "Android: Build + Install + Launch (GitHub Container)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/build-android-container.ps1"],
            "presentation": { "group": "android", "order": 6 }
        },
        // ═══════════════════════════════════════════════════════════════════════
        // GITHUB DEPLOY
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "GitHub Deploy: All",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","all"],
            
            "presentation": { "group": "deploy", "order": 1 }
        },
        {
            "name": "GitHub Deploy: Cloud Run only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","cloudrun"],
            
            "presentation": { "group": "deploy", "order": 2 }
        },
        {
            "name": "GitHub Deploy: Firebase Hosting only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","hosting"],
            
            "presentation": { "group": "deploy", "order": 3 }
        },
        {
            "name": "GitHub Deploy: Firestore Rules only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/deploy-github.ps1","-Target","functions"],
            "presentation": { "group": "deploy", "order": 4 }
        },
        // ═══════════════════════════════════════════════════════════════════════
        // ANDROID: GITHUB EDITION
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "Android (GitHub): Deploy Playwright Proxy Container to GitHub",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Deploy Playwright Proxy Container to GitHub",
            "presentation": { "group": "android-github", "order": 1 }
        },
        {
            "name": "Android (GitHub): Build Web (Metro) and Deploy to GitHub Pages",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Build Web (Metro) and Deploy to GitHub Pages",
            "presentation": { "group": "android-github", "order": 2 }
        },
        {
            "name": "Android (GitHub): Check ADB Device, Build & Deploy Android App",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Check ADB Device, Build & Deploy Android App",
            "presentation": { "group": "android-github", "order": 3 }
        },
        {
            "name": "Android (GitHub): Deploy All (Proxy, Web, Android)",
            "type": "node",
            "request": "launch",
                "preLaunchTask": [
                    "Deploy Playwright Proxy Container to GitHub",
                    "Build Web (Metro) and Deploy to GitHub Pages",
                    "Check ADB Device, Build & Deploy Android App"
                ],
            "presentation": { "group": "android-github", "order": 4 }
        },
        // ═══════════════════════════════════════════════════════════════════════
        // ANDROID: GITHUB FULL AUTOMATION
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "Android: GitHub Full Automation (Build + Push + Test)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/scripts/run-full-automation.ps1"],
            "presentation": { "group": "android", "order": 99 },
                "preLaunchTask": [
                    "Ensure GitHub CLI is installed and authenticated",
                    "[GitHub] Deploy: All"
                ],
            "postDebugTask": "Show build and test results in VS Code terminal"
        },
        // 
        // PROXY / FUNCTIONS (Node.js debug)
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "Debug: Proxy server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/run-proxy.ps1"],
            "skipFiles": ["<node_internals>/**"],
            "presentation": { "group": "debug", "order": 1 }
        },
        {
            "name": "Debug: Attach to proxy (9229)",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "address": "localhost",
            "localRoot": "${workspaceFolder}/functions",
            "remoteRoot": "${workspaceFolder}/functions",
            "skipFiles": ["<node_internals>/**"],
            "restart": true,
            "presentation": { "group": "debug", "order": 2 }
        },
        {
            "name": "Dev: Start Chrome debug session",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/start-chrome-debug.ps1"],
            "presentation": { "group": "dev", "order": 3 }
        },
        // ═══════════════════════════════════════════════════════════════════════
        // ANDROID: APK INSTALL TASK
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "Android: Install APK to device",
            "type": "process",
            "request": "launch",
            "preLaunchTask": "Install APK to device",
            "presentation": { "group": "android", "order": 100 }
        },
        // ═══════════════════════════════════════════════════════════════════════
        // FULL AUTOMATION: GH WORKFLOW + APK INSTALL
        // ═══════════════════════════════════════════════════════════════════════
        {
            "name": "Full Automation: Build, Download, Install APK",
            "type": "process",
            "request": "launch",
            "preLaunchTask": "Full Automation: Build, Download, Install APK",
            "presentation": { "group": "android", "order": 101 }
        },
        {
            "name": "Android: Poll npm run android until success",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/poll-android-build.js",
            "presentation": { "group": "android", "order": 99 }
        },
        {
            "name": "General: Poll npm script until success",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/poll-android-build.js",
            "args": ["android"],
            "presentation": { "group": "general", "order": 99 }
        }
    ]
}