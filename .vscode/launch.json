{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Web",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Run Web",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Android",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Run Android",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Proxy",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Run Proxy",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Build Web",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Build Web",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Sync Credentials",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Sync Credentials",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Antigravity Watch",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/orchestrator.service.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Orchestrator (Foreground)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/orchestrator.service.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Stop Antigravity",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Stop Antigravity",
            "cwd": "${workspaceFolder}"
        }
    ]
}