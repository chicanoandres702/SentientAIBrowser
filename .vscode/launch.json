{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Web (Development)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "web"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "preLaunchTask": "npm: web"
        },
        {
            "name": "Web with Debug",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "pathMapping": {
                "/": "${workspaceFolder}",
                "/static": "${workspaceFolder}"
            },
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Expo (Managed)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "start"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Android",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "android"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Android",
            "cwd": "${workspaceFolder}",
            "type": "reactnative",
            "request": "launch",
            "platform": "android"
        },
        {
            "name": "Sync Cloud Logic (Deploy All)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloud.bat",
            "console": "integratedTerminal"
        },
        {
            "name": "Firestore: Deploy Rules Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "firebase",
            "runtimeArgs": ["deploy", "--only", "firestore:rules"],
            "console": "integratedTerminal"
        },
        {
            "name": "Firestore: Deploy Indexes Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "firebase",
            "runtimeArgs": ["deploy", "--only", "firestore:indexes"],
            "console": "integratedTerminal"
        },
        {
            "name": "☁️ Deploy Functions (Build TS → Deploy)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "cmd",
            "runtimeArgs": [
                "/c",
                "cd functions && npm run build && cd .. && firebase deploy --only functions"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "🖥️ Deploy Frontend (TSX → Hosting)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "./deploy-frontend.ps1"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Proxy: Build & Deploy All",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloudrun.bat",
            "runtimeArgs": ["all"],
            "console": "integratedTerminal"
        },
        {
            "name": "Proxy: Manual Build (Docker)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloudrun.bat",
            "runtimeArgs": ["build"],
            "console": "integratedTerminal"
        },
        {
            "name": "Proxy: Manual Deploy (GCR)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/deploy-cloudrun.bat",
            "runtimeArgs": ["deploy"],
            "console": "integratedTerminal"
        },
        {
            "name": "Start Local Cloud (Emulator)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/debug-local-cloud.bat",
            "console": "integratedTerminal"
        },

        // ── GitHub Actions Deploy ──────────────────────────────
        {
            "name": "🚀 GitHub Deploy: All",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "all"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "🔥 GitHub Deploy: Hosting Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "hosting"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "⚡ GitHub Deploy: Functions Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "functions"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "☁️ GitHub Deploy: Cloud Run Only",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "powershell",
            "runtimeArgs": [
                "-ExecutionPolicy", "Bypass",
                "-File", "${workspaceFolder}/deploy-github.ps1",
                "-Target", "cloudrun"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Web + Chrome Debug",
            "configurations": ["Web (Development)", "Web with Debug"],
            "stopOnEntry": false
        }
    ]
}